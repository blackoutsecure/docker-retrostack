# EditorConfig - Enforce consistent code style across the project
# See https://editorconfig.org/ for details

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

[{Dockerfile*,*.yml,*.yaml}]
indent_style = space
indent_size = 2

[{*.sh,**/*.sh,root/etc/s6-overlay/s6-rc.d/**}]
indent_style = space
indent_size = 2

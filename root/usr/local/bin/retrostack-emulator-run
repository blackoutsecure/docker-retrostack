#!/usr/bin/env bash
# retrostack-emulator-run — Entrypoint for RetroStack emulator containers.
# Copyright (c) 2026 Blackout Secure (https://blackoutsecure.app). MIT License. See LICENSE.
set -euo pipefail

# shellcheck source=/dev/null
source /usr/local/lib/retrostack-lib.sh

rs_require_emulator_name
rs_validate_binary
rs_setup_display
rs_setup_audio
rs_setup_gamepad

EMU_CONFIG_HOME="/config/${EMULATOR_NAME}"
mkdir -p "${EMU_CONFIG_HOME}"

setup_retroarch_config() {
  export XDG_CONFIG_HOME="${EMU_CONFIG_HOME}"
  mkdir -p "${EMU_CONFIG_HOME}/retroarch"/{saves,states,logs,system}
  if [[ -d /bios && ! -e "${EMU_CONFIG_HOME}/retroarch/system/bios" ]]; then
    ln -sf /bios "${EMU_CONFIG_HOME}/retroarch/system/bios"
  fi
  if [[ -f "${EMU_CONFIG_HOME}/retroarch/retroarch.cfg" ]]; then
    return
  fi
  rs_log "Writing default retroarch.cfg"
  local core_dir
  core_dir="$(rs_find_libretro_dir)"
  cat > "${EMU_CONFIG_HOME}/retroarch/retroarch.cfg" <<-CFG
	libretro_directory = "${core_dir}"
	video_driver = "gl"
	audio_driver = "pulse"
	input_driver = "udev"
	savefile_directory = "${EMU_CONFIG_HOME}/retroarch/saves"
	savestate_directory = "${EMU_CONFIG_HOME}/retroarch/states"
	system_directory = "${EMU_CONFIG_HOME}/retroarch/system"
	log_dir = "${EMU_CONFIG_HOME}/retroarch/logs"
	rgui_browser_directory = "/roms"
	menu_driver = "ozone"
	CFG
}

case "${EMULATOR_NAME}" in
  retroarch)   setup_retroarch_config ;;
  ppsspp)
    export XDG_CONFIG_HOME="${EMU_CONFIG_HOME}"
    mkdir -p "${EMU_CONFIG_HOME}/ppsspp/PSP"/{SAVEDATA,PPSSPP_STATE}
    ;;
  dolphin-emu)
    export XDG_DATA_HOME="${EMU_CONFIG_HOME}"
    mkdir -p "${EMU_CONFIG_HOME}/dolphin-emu"/{Config,GC,Wii,StateSaves,Dump}
    if [[ -d /bios && ! -e "${EMU_CONFIG_HOME}/dolphin-emu/GC/bios" ]]; then
      ln -sf /bios "${EMU_CONFIG_HOME}/dolphin-emu/GC/bios"
    fi
    ;;
esac

run_emulator() {
  local args=("$@")
  case "${EMULATOR_NAME}" in
    retroarch)
      local resolved=() i=0
      while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
          --core|-c)
            i=$((i + 1))
            local p
            p="$(rs_resolve_core "${args[$i]}")" || rs_die "core '${args[$i]}' not found"
            resolved+=("-L" "$p")
            ;;
          *) resolved+=("${args[$i]}") ;;
        esac
        i=$((i + 1))
      done
      "${EMULATOR_BINARY}" "${resolved[@]}"
      ;;
    dolphin-emu)
      [[ -x /usr/bin/dolphin-emu-nogui ]] && exec /usr/bin/dolphin-emu-nogui "${args[@]}"
      "${EMULATOR_BINARY}" "${args[@]}"
      ;;
    *) "${EMULATOR_BINARY}" "${args[@]}" ;;
  esac
}

EXTRA_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      echo "Usage: standalone: <entrypoint> [--core <core>] [args...] <rom>"
      echo "       daemon:     <entrypoint>  (no args — listens on FIFO)"
      exit 0 ;;
    --) shift; EXTRA_ARGS+=("$@"); break ;;
    *)  EXTRA_ARGS+=("$1"); shift ;;
  esac
done

IDLE_TIMEOUT="${RETROSTACK_IDLE_TIMEOUT:-600}"
FRONTEND_MODE="${RETROSTACK_FRONTEND_MODE:-standalone}"

if [[ "${FRONTEND_MODE}" == "standalone" && ${#EXTRA_ARGS[@]} -eq 0 ]]; then
  rs_log "Standalone frontend mode — launching ${EMULATOR_NAME}"
  case "${EMULATOR_NAME}" in
    retroarch)    exec "${EMULATOR_BINARY}" ;;
    dolphin-emu)  exec "${EMULATOR_BINARY}" ;;
    *)            exec "${EMULATOR_BINARY}" ;;
  esac
fi

if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
  CMD_PIPE="${RETROSTACK_CONTROL_DIR}/${EMULATOR_NAME}.cmd"
  STATUS_PIPE="${RETROSTACK_CONTROL_DIR}/${EMULATOR_NAME}.status"

  mkdir -p "${RETROSTACK_CONTROL_DIR}"
  rm -f "${CMD_PIPE}" "${STATUS_PIPE}"
  mkfifo "${CMD_PIPE}" "${STATUS_PIPE}"
  chmod 666 "${CMD_PIPE}" "${STATUS_PIPE}"

  rs_log "Daemon mode — version: $(rs_emulator_version)"
  [[ "${EMULATOR_NAME}" == "retroarch" ]] && rs_log "Available cores: $(rs_count_cores)"
  rs_log "Control pipe: ${CMD_PIPE}"
  if [[ "${IDLE_TIMEOUT}" -gt 0 ]]; then
    rs_log "Idle timeout: ${IDLE_TIMEOUT}s"
  fi
  rs_log "Ready — waiting for launch commands from frontend (e.g. ES-DE)"

  cleanup() { rs_log "Shutting down."; rm -f "${CMD_PIPE}" "${STATUS_PIPE}"; }
  trap 'cleanup; exit 0' SIGTERM SIGINT

  while true; do
    if [[ "${IDLE_TIMEOUT}" -gt 0 ]]; then
      if ! timeout "${IDLE_TIMEOUT}" bash -c "read -r CMD_LINE < \"${CMD_PIPE}\" && echo \"\${CMD_LINE}\"" > /tmp/rs_cmd 2>/dev/null; then
        rs_log "Idle timeout (${IDLE_TIMEOUT}s) reached — no launch commands received. Exiting."
        cleanup
        exit 0
      fi
      CMD_LINE="$(cat /tmp/rs_cmd)"
      rm -f /tmp/rs_cmd
    else
      read -r CMD_LINE < "${CMD_PIPE}" || continue
    fi
    [[ -z "${CMD_LINE}" ]] && continue
    rs_log "Launch: ${CMD_LINE}"

    CMD_ARGS=()
    while IFS= read -r -d '' arg; do CMD_ARGS+=("${arg}"); done < <(printf '%s' "${CMD_LINE}" | tr '\x1f' '\0')
    [[ ${#CMD_ARGS[@]} -eq 0 ]] && read -ra CMD_ARGS <<< "${CMD_LINE}"

    EXIT_CODE=0
    run_emulator "${CMD_ARGS[@]}" || EXIT_CODE=$?
    rs_log "Exited: ${EXIT_CODE}"
    echo "${EXIT_CODE}" > "${STATUS_PIPE}"

    rs_log "Emulator process ended — stopping container."
    cleanup
    exit "${EXIT_CODE}"
  done
fi

rs_log "Standalone: ${EMULATOR_NAME}"
run_emulator "${EXTRA_ARGS[@]}"

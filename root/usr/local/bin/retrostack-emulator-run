#!/usr/bin/env bash
# retrostack-emulator-run — Entrypoint for RetroStack emulator containers.
# Copyright (c) 2026 Blackout Secure (https://blackoutsecure.app). MIT License. See LICENSE.
set -euo pipefail

# shellcheck source=/dev/null
source /usr/local/lib/retrostack-lib.sh

rs_require_emulator_name
rs_validate_binary
rs_setup_display
rs_setup_audio
rs_setup_gamepad

EMU_CONFIG_HOME="/config/${EMULATOR_NAME}"
mkdir -p "${EMU_CONFIG_HOME}"

setup_retroarch_config() {
  export XDG_CONFIG_HOME="${EMU_CONFIG_HOME}"
  mkdir -p "${EMU_CONFIG_HOME}/retroarch"/{saves,states,logs,system}
  if [[ -d /bios && ! -e "${EMU_CONFIG_HOME}/retroarch/system/bios" ]]; then
    ln -sf /bios "${EMU_CONFIG_HOME}/retroarch/system/bios"
  fi
  if [[ -f "${EMU_CONFIG_HOME}/retroarch/retroarch.cfg" ]]; then
    return
  fi
  rs_log "Writing default retroarch.cfg"
  local core_dir
  core_dir="$(rs_find_libretro_dir)"
  cat > "${EMU_CONFIG_HOME}/retroarch/retroarch.cfg" <<-CFG
	libretro_directory = "${core_dir}"
	video_driver = "gl"
	audio_driver = "pulse"
	input_driver = "udev"
	savefile_directory = "${EMU_CONFIG_HOME}/retroarch/saves"
	savestate_directory = "${EMU_CONFIG_HOME}/retroarch/states"
	system_directory = "${EMU_CONFIG_HOME}/retroarch/system"
	log_dir = "${EMU_CONFIG_HOME}/retroarch/logs"
	rgui_browser_directory = "/roms"
	menu_driver = "ozone"
	CFG
}

case "${EMULATOR_NAME}" in
  retroarch)   setup_retroarch_config ;;
  ppsspp)
    export XDG_CONFIG_HOME="${EMU_CONFIG_HOME}"
    mkdir -p "${EMU_CONFIG_HOME}/ppsspp/PSP"/{SAVEDATA,PPSSPP_STATE}
    ;;
  dolphin-emu)
    export XDG_DATA_HOME="${EMU_CONFIG_HOME}"
    mkdir -p "${EMU_CONFIG_HOME}/dolphin-emu"/{Config,GC,Wii,StateSaves,Dump}
    if [[ -d /bios && ! -e "${EMU_CONFIG_HOME}/dolphin-emu/GC/bios" ]]; then
      ln -sf /bios "${EMU_CONFIG_HOME}/dolphin-emu/GC/bios"
    fi
    ;;
esac

run_emulator() {
  local args=("$@")
  case "${EMULATOR_NAME}" in
    retroarch)
      local resolved=() i=0
      while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
          --core|-c)
            i=$((i + 1))
            local p
            p="$(rs_resolve_core "${args[$i]}")" || rs_die "core '${args[$i]}' not found"
            resolved+=("-L" "$p")
            ;;
          *) resolved+=("${args[$i]}") ;;
        esac
        i=$((i + 1))
      done
      "${EMULATOR_BINARY}" "${resolved[@]}"
      ;;
    dolphin-emu)
      [[ -x /usr/bin/dolphin-emu-nogui ]] && exec /usr/bin/dolphin-emu-nogui "${args[@]}"
      "${EMULATOR_BINARY}" "${args[@]}"
      ;;
    *) "${EMULATOR_BINARY}" "${args[@]}" ;;
  esac
}

EXTRA_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      echo "Usage: standalone: <entrypoint> [--core <core>] [args...] <rom>"
      echo "       daemon:     <entrypoint>  (no args — listens on FIFO)"
      exit 0 ;;
    --) shift; EXTRA_ARGS+=("$@"); break ;;
    *)  EXTRA_ARGS+=("$1"); shift ;;
  esac
done

IDLE_TIMEOUT="${RETROSTACK_IDLE_TIMEOUT:-600}"
FRONTEND_MODE="${RETROSTACK_FRONTEND_MODE:-standalone}"
USE_INTERNAL_X="${RETROSTACK_USE_INTERNAL_X:-1}"

rs_log "──────────────────────────────────────"
rs_log "RetroStack $(rs_retrostack_version)"
rs_log "Emulator:      ${EMULATOR_NAME}"
rs_log "Binary:        ${EMULATOR_BINARY}"
rs_log "Version:       $(rs_emulator_version)"
[[ "${EMULATOR_NAME}" == "retroarch" ]] && rs_log "Cores:         $(rs_count_cores)"
rs_log "Mode:          ${FRONTEND_MODE}"
if [[ "${FRONTEND_MODE}" == "standalone" ]]; then
  rs_log "Internal X:    ${USE_INTERNAL_X}"
fi
rs_log "DISPLAY:       ${DISPLAY:-unset}"
rs_log "XDG_RUNTIME_DIR: ${XDG_RUNTIME_DIR:-unset}"
rs_log "PULSE_SERVER:  ${PULSE_SERVER:-unset}"
rs_log "Audio output:  ${RETROSTACK_AUDIO_OUTPUT:-auto}"
rs_log "Config:        ${EMU_CONFIG_HOME}"
X11_DISPLAY_NUM="${DISPLAY#:}"
X11_SOCKET="/tmp/.X11-unix/X${X11_DISPLAY_NUM%%.*}"
if [[ -S "${X11_SOCKET}" ]]; then
  rs_log "X11 socket:    ${X11_SOCKET} (ok)"
else
  rs_log "X11 socket:    ${X11_SOCKET} (NOT FOUND)"
fi
[[ -d /dev/dri ]] && rs_log "GPU:           /dev/dri (ok)" || rs_log "GPU:           /dev/dri (NOT FOUND)"
rs_log "──────────────────────────────────────"

if [[ "${FRONTEND_MODE}" == "standalone" && ${#EXTRA_ARGS[@]} -eq 0 ]]; then
  rs_setup_device_groups
  rs_setup_udev

  # Seed bundled demo ROMs on first boot if /roms is empty
  if [[ -d /defaults/roms ]]; then
    rom_count="$(find /roms -mindepth 1 -maxdepth 2 -type f 2>/dev/null | wc -l)"
    if [[ "${rom_count}" -eq 0 ]]; then
      cp -rn /defaults/roms/* /roms/ 2>/dev/null || true
      rs_log "Seeded demo ROMs into /roms"
    fi
  fi

  STARTED_INTERNAL_X=false

  if [[ ! -S "${X11_SOCKET}" ]]; then
    if [[ "${USE_INTERNAL_X}" == "1" ]]; then
      if rs_start_internal_x; then
        STARTED_INTERNAL_X=true
      else
        rs_log "Internal Xorg failed. Check GPU passthrough (/dev/dri)."
        rs_log "  Or bind-mount a host X11 socket: -v /tmp/.X11-unix:/tmp/.X11-unix:ro"
        sleep infinity &
        wait
      fi
    else
      rs_log "ERROR: No X11 socket at ${X11_SOCKET} and internal X is disabled"
      rs_log "  Set RETROSTACK_USE_INTERNAL_X=1 or bind-mount /tmp/.X11-unix"
      sleep infinity &
      wait
    fi
  fi

  rs_setup_pulse

  rs_log "Launching ${EMULATOR_NAME} in standalone mode"

  FAIL_STAMP="/tmp/retrostack-standalone-fail"
  FAIL_COUNT=0
  if [[ -f "${FAIL_STAMP}" ]]; then
    FAIL_COUNT=$(cat "${FAIL_STAMP}")
  fi

  if [[ ${FAIL_COUNT} -ge 3 ]]; then
    rs_log "ERROR: ${EMULATOR_NAME} failed ${FAIL_COUNT} consecutive times — stopping."
    rs_log "Last attempt diagnostics:"
    rs_log "  DISPLAY=${DISPLAY:-unset}"
    rs_log "  XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-unset}"
    [[ -S /tmp/.X11-unix/X${DISPLAY#:} ]] && rs_log "  X11 socket: found" || rs_log "  X11 socket: NOT FOUND — is an X server running?"
    [[ -d /dev/dri ]] && rs_log "  /dev/dri: found" || rs_log "  /dev/dri: NOT FOUND — GPU passthrough missing?"
    rs_log "Check: X server running? DISPLAY correct? /dev/dri mounted?"
    rm -f "${FAIL_STAMP}"
    sleep infinity &
    wait
  fi

  echo $(( FAIL_COUNT + 1 )) > "${FAIL_STAMP}"

  EXIT_CODE=0
  "${EMULATOR_BINARY}" || EXIT_CODE=$?

  if [[ ${EXIT_CODE} -eq 0 ]]; then
    rm -f "${FAIL_STAMP}"
    rs_log "${EMULATOR_NAME} exited cleanly."
  else
    rs_log "${EMULATOR_NAME} exited with code ${EXIT_CODE}"
  fi
  ${STARTED_INTERNAL_X} && rs_stop_internal_x
  exit "${EXIT_CODE}"
fi

if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
  CMD_PIPE="${RETROSTACK_CONTROL_DIR}/${EMULATOR_NAME}.cmd"
  STATUS_PIPE="${RETROSTACK_CONTROL_DIR}/${EMULATOR_NAME}.status"

  mkdir -p "${RETROSTACK_CONTROL_DIR}"
  rm -f "${CMD_PIPE}" "${STATUS_PIPE}"
  mkfifo "${CMD_PIPE}" "${STATUS_PIPE}"
  chmod 666 "${CMD_PIPE}" "${STATUS_PIPE}"

  rs_log "Daemon mode"
  rs_log "Control pipe: ${CMD_PIPE}"
  if [[ "${IDLE_TIMEOUT}" -gt 0 ]]; then
    rs_log "Idle timeout: ${IDLE_TIMEOUT}s"
  fi
  rs_log "Ready — waiting for launch commands from frontend (e.g. ES-DE)"

  cleanup() { rs_log "Shutting down."; rm -f "${CMD_PIPE}" "${STATUS_PIPE}"; }
  trap 'cleanup; exit 0' SIGTERM SIGINT

  while true; do
    if [[ "${IDLE_TIMEOUT}" -gt 0 ]]; then
      if ! timeout "${IDLE_TIMEOUT}" bash -c "read -r CMD_LINE < \"${CMD_PIPE}\" && echo \"\${CMD_LINE}\"" > /tmp/rs_cmd 2>/dev/null; then
        rs_log "Idle timeout (${IDLE_TIMEOUT}s) reached — no launch commands received. Exiting."
        cleanup
        exit 0
      fi
      CMD_LINE="$(cat /tmp/rs_cmd)"
      rm -f /tmp/rs_cmd
    else
      read -r CMD_LINE < "${CMD_PIPE}" || continue
    fi
    [[ -z "${CMD_LINE}" ]] && continue
    rs_log "Launch: ${CMD_LINE}"

    CMD_ARGS=()
    while IFS= read -r -d '' arg; do CMD_ARGS+=("${arg}"); done < <(printf '%s' "${CMD_LINE}" | tr '\x1f' '\0')
    [[ ${#CMD_ARGS[@]} -eq 0 ]] && read -ra CMD_ARGS <<< "${CMD_LINE}"

    EXIT_CODE=0
    run_emulator "${CMD_ARGS[@]}" || EXIT_CODE=$?
    rs_log "Exited: ${EXIT_CODE}"
    echo "${EXIT_CODE}" > "${STATUS_PIPE}"

    rs_log "Emulator process ended — stopping container."
    cleanup
    exit "${EXIT_CODE}"
  done
fi

rs_log "Standalone: ${EMULATOR_NAME}"
run_emulator "${EXTRA_ARGS[@]}"

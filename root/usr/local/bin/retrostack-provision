#!/usr/bin/env bash
# retrostack-provision — Export emulator binary + libs to a shared volume.
# Copyright (c) 2026 Blackout Secure (https://blackoutsecure.app). MIT License. See LICENSE.
set -euo pipefail

# shellcheck source=/dev/null
source /usr/local/lib/retrostack-lib.sh

rs_require_emulator_name
rs_validate_binary

EXPORT_DIR="/export/${EMULATOR_NAME}"
SYSTEM_LIBS="^(libc|libm|libdl|librt|libpthread|ld-linux|libgcc_s|libstdc\+\+)"

rs_log "Provisioning from ${EMULATOR_BINARY}"
mkdir -p "${EXPORT_DIR}"/{bin,lib}

cp -a "${EMULATOR_BINARY}" "${EXPORT_DIR}/bin/${EMULATOR_NAME}"
chmod 755 "${EXPORT_DIR}/bin/${EMULATOR_NAME}"

copy_libs_for() {
  ldd "$1" 2>/dev/null | while read -r line; do
    [[ "${line}" =~ =\>\ (/[^\ ]+) ]] || continue
    local lp="${BASH_REMATCH[1]}" ln
    ln="$(basename "${lp}")"
    [[ "${ln}" =~ ${SYSTEM_LIBS} || -f "${EXPORT_DIR}/lib/${ln}" ]] && continue
    cp -aL "${lp}" "${EXPORT_DIR}/lib/${ln}"
  done
}

copy_libs_for "${EMULATOR_BINARY}"
rs_log "Copied $(find "${EXPORT_DIR}/lib" -maxdepth 1 -type f | wc -l) shared libraries"

if [[ "${EMULATOR_NAME}" == "retroarch" ]]; then
  mkdir -p "${EXPORT_DIR}/cores"
  count=0
  for d in /usr/lib/libretro /usr/lib/*/libretro; do
    [[ -d "$d" ]] || continue
    for core in "$d"/*.so; do
      [[ -f "$core" ]] || continue
      cp -a "$core" "${EXPORT_DIR}/cores/$(basename "$core")"
      copy_libs_for "$core"
      count=$((count + 1))
    done
  done
  rs_log "Copied ${count} libretro cores"
  printf '%s\n' \
    'libretro_directory = "/emulators/retroarch/cores"' \
    'video_driver = "gl"' \
    'audio_driver = "pulse"' \
    'input_driver = "udev"' \
    > "${EXPORT_DIR}/retroarch.cfg"
fi

ver="$(rs_emulator_version)"
echo "${ver:-unknown}" > "${EXPORT_DIR}/VERSION"
[[ -n "$ver" ]] && rs_log "Version: ${ver}"
rs_log "Done. Size: $(du -sh "${EXPORT_DIR}" | cut -f1)"
